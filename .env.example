# Copy this file to `.env.local` and fill in values. Never commit `.env.local`.
# Required by `/api/translate` and Google TTS routes:
GEMINI_API_KEY=
# Required by `/api/tts` (MiniMax) and `/api/tts-poll`:
REPLICATE_API_TOKEN=
# Required by `/api/voice/clone` and ElevenLabs branch of `/api/tts` (instant voice clone + TTS):
ELEVENLABS_API_KEY=
# Optional — defaults to eleven_multilingual_v2
# ELEVENLABS_TTS_MODEL_ID=
